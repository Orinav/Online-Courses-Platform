generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      String   @default("CUSTOMER") // Can be "CUSTOMER" or "ADMIN"
  createdAt DateTime @default(now())
}

model Course {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  price       Float
  lessons     Lesson[]
}

model Lesson {
  id       Int    @id @default(autoincrement())
  title    String
  videoUrl String
  courseId Int
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
}
